PORT=3001
JWT_SECRET=sua-chave-secreta-aqui-mude-em-producao
DB_PATH=./data/emissor.db

# NFS-e Nacional
NFSE_API_URL_PROD=https://sefin.nfse.gov.br/sefinnacional
NFSE_API_URL_HOMOLOG=https://sefin.nfse.gov.br/sefinnacional/homologacao
NFSE_AMBIENTE=homologacao

# WhatsApp - Provider escolhido: 'meta' | 'blip' | 'evolution' | 'zapi'
# 'zapi' e 'evolution' = APIs não-oficiais que suportam grupos
# 'zapi' = serviço gerenciado pago (recomendado, ~R$99/mo)
WHATSAPP_PROVIDER=zapi

# WhatsApp Business API (Meta Cloud API) — só se WHATSAPP_PROVIDER=meta
WHATSAPP_PHONE_ID=seu_phone_number_id
WHATSAPP_TOKEN=seu_access_token_permanente
WHATSAPP_VERIFY_TOKEN=marcal_verify_2026

# Blip (BSP) — só se WHATSAPP_PROVIDER=blip
BLIP_API_KEY=
BLIP_BOT_IDENTIFIER=

# Evolution API — só se WHATSAPP_PROVIDER=evolution
# Docs: https://doc.evolution-api.com
EVOLUTION_API_URL=https://sua-evolution.up.railway.app
EVOLUTION_API_KEY=sua_api_key_global
EVOLUTION_INSTANCE=ana-marcal

# Z-API (z-api.io) — só se WHATSAPP_PROVIDER=zapi
# Docs: https://developer.z-api.io
ZAPI_INSTANCE_ID=sua_instance_id
ZAPI_TOKEN=seu_token_da_instancia
ZAPI_CLIENT_TOKEN=seu_account_security_token

# Whitelist de destinos da ANA (modo piloto)
# Quando preenchido, a ANA SÓ responde pra esses destinos (ignora todos os outros)
# Formato: separado por vírgula. Aceita grupo (com @g.us) ou telefone (só dígitos).
# Exemplo: ANA_WHITELIST=120363025552242228@g.us,5541999999999
# Deixe vazio pra desativar o filtro (ANA responde em tudo).
ANA_WHITELIST=

# Anthropic Claude API (Agente Inteligente)
ANTHROPIC_API_KEY=sua_chave_anthropic
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Modelo do validador de auto-qualidade (mais barato)
ANTHROPIC_VALIDADOR_MODEL=claude-haiku-4-5-20251001

# Telefone que recebe alerta WhatsApp quando ANA pede reforço (TRANSFERIR_HUMANO)
# Formato internacional: 55 + DDD + número, sem espaços ou caracteres
ANA_ADMIN_WHATSAPP=5541996104498

# URL base do app (usado em links das notificações)
APP_BASE_URL=https://emissor-nfs-marcal.onrender.com

# E-mail (Nodemailer)
EMAIL_PROVIDER=gmail
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_app_password
EMAIL_FROM_NAME=Marcal Contabilidade

# Integra Contador (SERPRO / RFB) — APIs oficiais pra DAS, DCTFWeb, PGDAS-D, etc.
# 1. Contrate em: https://loja.serpro.gov.br/integracontador
# 2. Pegue Consumer Key + Secret em https://cliente.serpro.gov.br
# 3. Faça upload do e-CNPJ A1 da Marçal via POST /api/integra-contador/certificado/upload
#    — a rota devolve a senha criptografada pra colar em MARCAL_CERT_SENHA_ENCRYPTED
SERPRO_CONSUMER_KEY=
SERPRO_CONSUMER_SECRET=
MARCAL_CNPJ=00000000000000
MARCAL_CERT_SENHA_ENCRYPTED=

# SIEG API (nova) — download automático de XMLs de notas fiscais
# Gerar em: sieg.com.br → Minha Conta → Integrações API SIEG (validade 60 meses, Full Access)
# Nota: a API antiga é depreciada em 31/07/2026 — nascemos já na nova.
SIEG_API_KEY=
SIEG_EMAIL=
SIEG_SYNC_ENABLED=false
SIEG_SYNC_CRON=30 6 * * *
